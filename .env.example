# Dedicated hot wallet for this reporter node. NEVER reuse a wallet that
# holds other funds, and never commit the real value of this file.
REPORTER_PRIVATE_KEY=0xPLACEHOLDER_REPLACE_WITH_YOUR_OWN_KEY

# Network selection: local | sepolia | production
NETWORK=sepolia

RPC_URL=https://sepolia.example-rpc-provider.com/PLACEHOLDER_API_KEY
CHAIN_ID=11155111

# Optional override - if unset, resolved from src/addresses.json by CHAIN_ID.
ORACLE_ADDRESS=

# Public price + market discovery endpoints (see README - Data sources).
PRICE_SOURCE_URL=https://example.com/PLACEHOLDER/price-feed
MARKETS_API_URL=https://example.com/PLACEHOLDER/public/markets/open

# How often the reporter loop polls for reportable markets, in ms.
POLL_INTERVAL_MS=30000

# Treat a fetched price older than this as stale and skip the report.
STALE_PRICE_HOURS=12

# If true, the reporter loop auto-tops-up stake back above ACTIVE_THRESHOLD
# when it dips (e.g. after a slash). Off by default - top-ups spend your
# ETH without asking, so opt in deliberately.
AUTO_TOPUP=false
