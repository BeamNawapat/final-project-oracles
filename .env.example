# Dedicated hot wallet for this reporter node. NEVER reuse a wallet that
# holds other funds, and never commit the real value of this file.
REPORTER_PRIVATE_KEY=0xPLACEHOLDER_REPLACE_WITH_YOUR_OWN_KEY

# Network selection: local | sepolia | production
NETWORK=sepolia

RPC_URL=https://sepolia.example-rpc-provider.com/PLACEHOLDER_API_KEY
CHAIN_ID=11155111

# Optional override - if unset, resolved from src/addresses.json by CHAIN_ID.
ORACLE_ADDRESS=

# Public price + market discovery endpoints (see README - Data sources).
# PRICE_SOURCE_URL is now the FALLBACK feed - the reporter scrapes MOC
# directly first (see MOC_* below) and only calls this if that scrape
# fails or MOC_ENABLED=false.
PRICE_SOURCE_URL=https://example.com/PLACEHOLDER/price-feed
MARKETS_API_URL=https://example.com/PLACEHOLDER/public/markets/open

# Direct MOC (Thai Ministry of Commerce) scrape - this is the PRIMARY price
# source (src/moc-scraper.ts), making this reporter an independent oracle
# instead of trusting the backend's own feed. Set to false to skip straight
# to PRICE_SOURCE_URL (e.g. if MOC is blocking this node's IP).
MOC_ENABLED=true
MOC_BASE_URL=https://data.moc.go.th/OpenData/GISProductPrice
# MOC is slow/flaky - per-navigation timeout and retry count for the scrape.
MOC_REQUEST_TIMEOUT_MS=90000
MOC_SCRAPE_ATTEMPTS=3

# How often the reporter loop polls for reportable markets, in ms.
POLL_INTERVAL_MS=30000

# Treat a fetched price older than this as stale and skip the report.
STALE_PRICE_HOURS=12

# If true, the reporter loop auto-tops-up stake back above ACTIVE_THRESHOLD
# when it dips (e.g. after a slash). Off by default - top-ups spend your
# ETH without asking, so opt in deliberately.
AUTO_TOPUP=false

# If true, the node self-registers on startup instead of requiring the
# explicit `cli register` command - for demo/docker-compose environments
# where a node should come up already staked. Off by default: this is a
# public reporter node and spending real ETH without an explicit command
# is not a safe default. See README - Auto-enroll (demo).
AUTO_ENROLL=false

# Stake to register with when AUTO_ENROLL=true, in ETH (e.g. "1.5"). Must be
# >= the contract's MIN_STAKE or it is ignored in favor of MIN_STAKE. Leave
# unset to register with exactly MIN_STAKE.
AUTO_ENROLL_STAKE=

# Opt-in OTLP traces + logs to a self-hosted SigNoz collector (src/otel-init.ts).
# Off by default - both of the below are unset. Same convention as the
# backend's OTEL_ENABLED/OTEL_EXPORTER_OTLP_ENDPOINT (backend/src/lib/otel.ts).
# OTEL_ENABLED=true
# Base URL only (no /v1/traces or /v1/logs suffix - otel-init.ts appends
# both itself), e.g. http://localhost:4318 for a local collector.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Comma-separated key=value pairs, e.g. "signoz-ingestion-key=xxx" for SigNoz
# Cloud. Omit for a local collector with no auth - this deploy is keyless.
# OTEL_EXPORTER_OTLP_HEADERS=
# OTEL_SERVICE_NAME=agricast-oracle-reporter
