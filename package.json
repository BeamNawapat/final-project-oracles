{
  "name": "@agricast/oracle-reporter",
  "version": "0.1.0",
  "description": "Standalone reporter node for the AgriCast oracle (AgriOracle.sol) - price staking, EIP-712 signing, and settlement/keeper commands.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/reporter.js",
    "cli": "tsx src/cli.ts",
    "dev": "tsx watch src/reporter.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
